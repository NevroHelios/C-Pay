# Stellar network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_BASE_FEE=100
ALLOW_CUSTOM_HORIZON=false
ALLOW_HTTP_HORIZON=false

# Stellar smart contract RPC and CLI
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_CLI_NETWORK=testnet
STELLAR_CLI_SOURCE_ACCOUNT=cpay-deployer

# C-Pay asset
ASSET_CODE=CPINR
ASSET_ISSUER_PUBLIC_KEY=G_ISSUER_PUBLIC_KEY
ASSET_DISTRIBUTION_PUBLIC_KEY=G_DISTRIBUTION_PUBLIC_KEY

# Contract administration
CONTRACT_ADMIN_PUBLIC_KEY=G_CONTRACT_ADMIN_PUBLIC_KEY
RELAYER_PUBLIC_KEY=G_RELAYER_PUBLIC_KEY
TOKEN_CONTRACT_ID=C_TOKEN_CONTRACT_ID
CPAY_CONTRACT_ID=C_CPAY_CONTRACT_ID

# Secrets are only for local setup scripts. Never put them in the app.
ASSET_ISSUER_SECRET=S_ISSUER_SECRET
ASSET_DISTRIBUTION_SECRET=S_DISTRIBUTION_SECRET

# Testnet setup
INITIAL_SUPPLY=1000000000
TRUSTLINE_LIMIT=1000000000
ASSET_HOME_DOMAIN=
LOCK_ISSUER_AFTER_SETUP=false
